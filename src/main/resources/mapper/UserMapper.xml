<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.good.zdisksystem.mapper.UserMapper">

    <select id="getUserRoles" resultType="string">
        SELECT r.code
        FROM user_role ur
                 LEFT JOIN role r ON ur.role_id = r.id
        WHERE ur.user_id = #{userId}
    </select>

    <select id="getRoleIdByCode" resultType="long">
        SELECT id
        FROM role
        WHERE code = #{code}
          and status = 1
    </select>

    <insert id="insertUserRole">
        INSERT INTO user_role (user_id, role_id)
        VALUES (#{userId}, #{roleId})
    </insert>

    <select id="getUserById" resultType="com.good.zdisksystem.entity.model.User">
        SELECT id,
               username,
               nickname,
               password,
               email,
               phone,
               avatar,
               storage_used,
               storage_max,
               status,
               create_time,
               update_time,
               last_login_time,
               last_login_ip
        FROM user
        WHERE id = #{userId}
    </select>

</mapper>
